{
  "name": "figxed-design-system-audit",
  "version": "2.0.0",
  "description": "Design System Audit & Adoption Analytics for Figma",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run build:ui -- --watch\" \"npm run build:code -- --watch\"",
    "build": "npm run build:ui && npm run build:code",
    "build:ui": "vite build --config vite.config.ts",
    "build:code": "vite build --config vite.config.code.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "framer-motion": "^12.34.0",
    "lucide-react": "^0.292.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-window": "^2.2.6",
    "recharts": "^2.10.3",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@figma/plugin-typings": "^1.98.0",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.10",
    "vite-plugin-singlefile": "^0.13.5"
  }
}
